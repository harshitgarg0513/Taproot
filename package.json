{
  "name": "sclare",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "vitest",
    "coverage": "vitest --coverage",
    "lint": "eslint .",
    "format": "prettier --write .",
    "check-format": "prettier --check .",
